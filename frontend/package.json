{
  "name": "evzone-effect-hub",
  "private": true,
  "version": "1.0.0",
  "description": "EVzone Effect Hub - premium AR/effect creator platform shell built with TypeScript, Vite, MUI and Tailwind.",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "backend:dev": "npm --prefix ../EVzone_Effect_Hub_Backend run start:dev",
    "backend:start": "npm --prefix ../EVzone_Effect_Hub_Backend run start",
    "backend:typecheck": "npm --prefix ../EVzone_Effect_Hub_Backend run typecheck",
    "dev": "vite --host 0.0.0.0",
    "format": "prettier --write .",
    "lint": "eslint .",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "@fontsource/inter": "^5.1.1",
    "@hookform/resolvers": "latest",
    "@mediapipe/tasks-vision": "latest",
    "@monaco-editor/react": "latest",
    "@mui/icons-material": "^6.4.0",
    "@mui/material": "^6.4.0",
    "@react-three/drei": "^9.0.0",
    "@react-three/fiber": "^8.0.0",
    "@tanstack/react-query": "latest",
    "@tanstack/react-table": "latest",
    "@xyflow/react": "latest",
    "browser-image-compression": "latest",
    "canvas-confetti": "latest",
    "clsx": "^2.1.1",
    "date-fns": "latest",
    "dexie": "latest",
    "file-saver": "latest",
    "framer-motion": "^11.18.2",
    "html-to-image": "latest",
    "html2canvas": "latest",
    "immer": "latest",
    "jspdf": "latest",
    "jspdf-autotable": "latest",
    "jszip": "latest",
    "localforage": "latest",
    "lucide-react": "latest",
    "monaco-editor": "latest",
    "nanoid": "latest",
    "papaparse": "latest",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "latest",
    "react-hook-form": "latest",
    "react-resizable-panels": "latest",
    "react-router-dom": "^7.1.3",
    "recharts": "latest",
    "sonner": "latest",
    "tailwind-merge": "^2.6.0",
    "three": "latest",
    "zod": "latest",
    "zustand": "^5.0.2"
