NODE_ENV=development
PORT=3777
API_PREFIX=api/v1
EVZONE_DATA_FILE=./data/evzone-effect-hub-backend.json
EVZONE_CORS_ORIGIN=http://localhost:5173
EVZONE_INTERNAL_ADMIN_KEY=
EVZONE_STUDIO_BRIDGE_NAME=EVzone Live Studio Bridge

